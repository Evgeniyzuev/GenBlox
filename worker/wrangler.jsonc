{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "genblox-realtime",
  "main": "src/index.js",
  "compatibility_date": "2026-07-03",
  "durable_objects": {
    "bindings": [
      {
        "name": "LOBBY",
        "class_name": "GameLobby"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameLobby"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
